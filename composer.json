{
    "name": "honestlydesign/etch-builders",
    "description": "Builder API for serializing Etch blocks, styles, and dynamic data.",
    "type": "library",
    "license": "MIT",
    "keywords": ["etch", "wordpress", "builder", "blocks", "gutenberg"],
    "authors": [
        {
            "name": "honestlydesign",
            "homepage": "https://github.com/honestlydesign"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "php-stubs/wordpress-stubs": "^6.6",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "HonestlyDesign\\EtchBuilders\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HonestlyDesign\\EtchBuilders\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=1G"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
